<?xml version="1.0" encoding="UTF-8" ?>
<server description="Lutece server">
    <featureManager>
        <feature>persistence-3.1</feature>
        <feature>beanValidation-3.0</feature>
        <feature>jndi-1.0</feature>
        <feature>jdbc-4.2</feature>
        <feature>localConnector-1.0</feature>
        <feature>cdi-4.0</feature>
        <feature>servlet-6.0</feature>
        <feature>pages-3.1</feature>
        <feature>mpConfig-3.1</feature>
        <feature>mail-2.1</feature>
        <feature>xmlBinding-4.0</feature>
        <feature>concurrent-3.0</feature>
        <feature>restfulWS-3.1</feature>
        <feature>jsonb-3.0</feature>
        <feature>mpHealth-4.0</feature>
        <feature>mpTelemetry-2.0</feature>
        <feature>sessionCache-1.0</feature>   <!-- Niveau 2 : replication de session HTTP via JCache -->
    </featureManager>
    <variable defaultValue="9090" name="http.port"/>
    <variable defaultValue="9443" name="https.port"/>
    <applicationManager autoExpand="true"/>
    <httpEndpoint host="*" httpPort="${http.port}" httpsPort="${https.port}" id="defaultHttpEndpoint"/>
    <mpTelemetry source="message, trace, ffdc"/>
    <application context-root="lutece" location="lutece.war" name="lutece" type="war"/>
    <applicationMonitor dropinsEnabled="false" updateTrigger="disabled"/>
    <library id="jdbcLib">
        <fileset dir="/config/apps/expanded/lutece.war/WEB-INF/lib/" includes="mariadb-java-client-*.jar"/>
    </library>
    <variable defaultValue="lutece" name="portal.user"/>
    <variable defaultValue="some_password" name="portal.password"/>
    <variable defaultValue="3306" name="portal.port"/>
    <variable defaultValue="core" name="portal.dbname"/>
    <variable defaultValue="mariadb" name="portal.serverName"/>

    <dataSource jndiName="jdbc/portal">
      <jdbcDriver libraryRef="jdbcLib"
          javax.sql.DataSource="org.mariadb.jdbc.MariaDbDataSource"
          javax.sql.ConnectionPoolDataSource="org.mariadb.jdbc.MariaDbDataSource"
          javax.sql.XADataSource="org.mariadb.jdbc.MariaDbDataSource"/>
      <properties
          url="jdbc:mariadb://${portal.serverName}:${portal.port}/${portal.dbname}"
          user="${portal.user}"
          password="${portal.password}"/>
    </dataSource>

    <!-- Level 2: HTTP session replication via JCache/Hazelcast.
         The session lives in the Hazelcast cluster -> survives node switching (sticky no longer needed).
         The Hazelcast jar is provided at server level (sessionCache initializes before the war is deployed). -->
    <library id="JCacheLib">
        <file name="/config/hazelcast/hazelcast-5.5.0.jar"/>
    </library>
<!-- writeContents MUST be GET_AND_SET_ATTRIBUTES (Liberty default is ONLY_SET_ATTRIBUTES).
         CDI @SessionScoped beans (every stateful v8 XPage: multi-step wizards, booking flows...)
         are mutated IN PLACE by Weld without a subsequent setAttribute. With the default, those
         mutations stay node-local and are NEVER replicated -> on a node switch the bean is seen
         empty and the wizard breaks ("session lost" / "form no longer valid"). GET_AND_SET_ATTRIBUTES
         writes back any attribute retrieved via getAttribute (which Weld does each request), so the
         bean's full state replicates. Plain setAttribute values (e.g. admin auth) replicate either
         way; that is why only the stateful CDI flow is affected, and why it is easy to miss. -->
    <httpSessionCache cacheManagerRef="CacheManager" writeContents="GET_AND_SET_ATTRIBUTES"/>
    <cacheManager id="CacheManager" uri="file:/config/hazelcast-session.xml">
        <cachingProvider jCacheLibraryRef="JCacheLib"/>
    </cacheManager>
</server>
